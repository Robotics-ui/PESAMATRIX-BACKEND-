datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AccountType {
  MASTER
  SUBSCRIBER
}

enum ConnectionStatus {
  DISCONNECTED
  PROVISIONING
  CONNECTED
  FAILED
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  passwordHash        String
  isAdmin             Boolean          @default(false)
  forcePasswordChange Boolean          @default(false)
  subscriptionStatus  Boolean          @default(false)
  subscriptionExpiry  DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  tradingAccounts     TradingAccount[]
  payments            Payment[]
  auditLogs           AuditLog[]
}

model TradingAccount {
  id               String                 @id @default(uuid())
  userId           String
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaApiAccountId String                 @unique
  accountType      AccountType
  login            String
  password         String
  server           String
  connectionStatus ConnectionStatus       @default(DISCONNECTED)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  managedStrategy  CopyStrategy?          @relation("MasterStrategy")
  subscriptions    StrategySubscription[] @relation("SubscriberAccount")
  replicationLogs  TradeReplicationLog[]
}

model CopyStrategy {
  id                String                 @id @default(uuid())
  masterAccountId   String                 @unique
  masterAccount     TradingAccount         @relation("MasterStrategy", fields: [masterAccountId], references: [id], onDelete: Cascade)
  metaApiStrategyId String                 @unique
  name              String
  createdAt         DateTime               @default(now())
  subscriptions     StrategySubscription[]
}

model StrategySubscription {
  id                  String         @id @default(uuid())
  subscriberAccountId String
  subscriberAccount   TradingAccount @relation("SubscriberAccount", fields: [subscriberAccountId], references: [id], onDelete: Cascade)
  strategyId          String
  strategy            CopyStrategy   @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  metaApiSubscriberId String         @unique
  riskMultiplier      Float          @default(1.0)
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([subscriberAccountId, strategyId])
}

model Payment {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Float
  phoneNumber       String
  subscriptionDays  Int      @default(30)
  mpesaReceipt      String?  @unique
  status            String
  merchantRequestID String   @unique
  checkoutRequestID String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SubscriptionSettings {
  id         String   @id @default(uuid())
  feePerDay  Float    @default(100.0)
  minDays    Int      @default(1)
  maxDays    Int      @default(30)
  updatedAt  DateTime @updatedAt
  updatedBy  String?
}

model TradeReplicationLog {
  id                  String         @id @default(uuid())
  masterTradeId       String
  subscriberAccountId String
  subscriberAccount   TradingAccount @relation(fields: [subscriberAccountId], references: [id], onDelete: Cascade)
  strategyId          String
  symbol              String
  action              String
  volume              Float?
  status              String
  errorMessage        String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  details     String?
  performedBy String?
  createdAt   DateTime @default(now())
}
